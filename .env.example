# Configuración de Auth.js
AUTH_SECRET="escribe-un-secreto-largo-aqui" # usa `npx auth secret` para generarlo

# Variables de Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Configuración de Turso
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Configuración de Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Configuración de Cloudflare Turnstile (Anti-Bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA" # Site key de prueba para pasar siempre
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA" # Secret key de prueba
